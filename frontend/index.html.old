<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#06080c">
<title>Euphorie</title>
<meta name="description" content="Euphorie is an AI Agent Command Center. Deploy specialized AI agents for strategy, code, research, communications, and security from one unified interface.">
<meta name="keywords" content="AI agents, AI command center, artificial intelligence, AI assistant, AI tools, ATLAS, CIPHER, ORACLE, HERALD, SENTINEL">
<link rel="canonical" href="https://euphorie.com/">
<meta property="og:type" content="website">
<meta property="og:url" content="https://euphorie.com/">
<meta property="og:title" content="Euphorie | AI Agent Command Center">
<meta property="og:description" content="Deploy specialized AI agents for strategy, code, research, communications, and security from one unified interface.">
<meta property="og:image" content="https://euphorie.com/logo.png">
<meta property="og:site_name" content="Euphorie">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="Euphorie | AI Agent Command Center">
<meta name="twitter:description" content="Deploy specialized AI agents for strategy, code, research, communications, and security from one unified interface.">
<meta name="twitter:image" content="https://euphorie.com/logo.png">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"SoftwareApplication","name":"Euphorie","description":"AI Agent Command Center. Deploy specialized AI agents for strategy, code, research, communications, and security.","url":"https://euphorie.com","applicationCategory":"ProductivityApplication","operatingSystem":"Web, iOS, Android","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"author":{"@type":"Organization","name":"Crene, Inc.","url":"https://crene.com"}}</script>
<link rel="manifest" href="/manifest.json">
<link rel="icon" href="/favicon.ico">
<link rel="apple-touch-icon" href="/logo.png">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<!-- Google Identity Services -->
<script src="https://accounts.google.com/gsi/client" async defer></script>
<script src="https://appleid.cdn-apple.com/appleauth/static/jsapi/appleid/1/en_US/appleid.auth.js"></script>
<!-- Microsoft MSAL -->
<script src="https://alcdn.msauth.net/browser/2.38.0/js/msal-browser.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#06080c;
  --bg-raised:#0a0e14;
  --bg-surface:#0d1117;
  --border:#151b25;
  --border-focus:#1e2a3a;
  --accent:#a78bfa;
  --accent-bright:#c4b5fd;
  --accent-dim:rgba(167,139,250,0.08);
  --accent-glow:rgba(167,139,250,0.18);
  --accent-blue:#00b4ff;
  --accent-orange:#ff6b35;
  --accent-green:#00e5a0;
  --accent-yellow:#ffd93d;
  --danger:#fb7185;
  --text:#e2e8f0;
  --text-dim:#4a5568;
  --text-muted:#2d3748;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bottom:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;width:100%;overflow:hidden;background:var(--bg);font-family:'JetBrains Mono',monospace;color:var(--text);-webkit-font-smoothing:antialiased}

/* ============ AUTH SCREEN ============ */
#auth-screen{position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--bg);gap:12px;transition:opacity .6s ease}
#auth-screen::before{content:'';position:absolute;inset:0;background:
  radial-gradient(ellipse at 30% 20%,rgba(167,139,250,0.06) 0%,transparent 50%),
  radial-gradient(ellipse at 70% 80%,rgba(124,58,237,0.04) 0%,transparent 50%);
  pointer-events:none}
#auth-screen::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,rgba(167,139,250,0.01) 0px,rgba(167,139,250,0.01) 1px,transparent 1px,transparent 3px);pointer-events:none}
#auth-screen.hidden{opacity:0;pointer-events:none}
.auth-logo{font-family:'Outfit',sans-serif;font-size:32px;font-weight:700;letter-spacing:6px;text-transform:uppercase;background:linear-gradient(135deg,#c4b5fd 0%,#a78bfa 50%,#7c3aed 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:2px}
.auth-sub{font-size:12px;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:24px}
.auth-btn{width:300px;padding:13px 18px;border:1px solid var(--border);border-radius:10px;background:var(--bg-raised);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:400;cursor:pointer;display:flex;align-items:center;gap:14px;transition:all .2s;position:relative;z-index:1;letter-spacing:.3px}
.auth-btn:hover{background:var(--bg-surface);border-color:var(--border-focus);transform:translateY(-1px)}
.auth-btn:active{transform:scale(.98) translateY(0)}
.auth-btn:disabled{opacity:0.4;cursor:wait;transform:none}
.auth-btn svg{width:18px;height:18px;flex-shrink:0}
.auth-divider{color:var(--text-muted);font-size:11px;margin:4px 0;letter-spacing:2px}
.auth-email-form{display:none;flex-direction:column;gap:8px;width:300px;position:relative;z-index:1}
.auth-email-form.show{display:flex}
.auth-input{padding:13px 14px;border:1px solid var(--border);border-radius:10px;background:var(--bg-raised);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;outline:none;transition:all .2s}
.auth-input:focus{border-color:var(--accent);background:var(--accent-dim);box-shadow:0 0 0 2px var(--accent-glow)}
.auth-input::placeholder{color:var(--text-muted)}
.auth-submit{padding:13px;border:none;border-radius:10px;background:var(--accent);color:#06080c;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;letter-spacing:.5px}
.auth-submit:hover{filter:brightness(1.1);transform:translateY(-1px)}
.auth-submit:active{transform:scale(.98)}
.auth-toggle{color:var(--accent);font-size:12px;cursor:pointer;background:none;border:none;font-family:'JetBrains Mono',monospace;margin-top:4px;letter-spacing:.3px}
.auth-error{color:var(--danger);font-size:12px;text-align:center;min-height:16px;letter-spacing:.3px}

/* ============ TERMINAL LAYOUT ============ */
#app{display:none;flex-direction:column;height:100%;position:relative}
#app.visible{display:flex}

/* Header */
#header{padding:max(var(--safe-top),10px) 16px 8px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:var(--bg);z-index:20;flex-shrink:0}
.header-brand{font-family:'Outfit',sans-serif;font-size:15px;font-weight:700;letter-spacing:4px;text-transform:uppercase;background:linear-gradient(135deg,#c4b5fd 0%,#a78bfa 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.header-meta{display:flex;align-items:center;gap:14px}
.header-meta span{font-size:10px;color:var(--text-muted);letter-spacing:.5px}
#header-credits{cursor:pointer;padding:5px 12px;border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;gap:6px;transition:all .2s}
#header-credits:hover{border-color:var(--accent);background:var(--accent-dim)}
#header-credits .dot{width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent-glow)}
#header-credits.low .dot{background:var(--danger);box-shadow:0 0 6px rgba(251,113,133,0.3)}

/* Agent bar */
#agent-bar{display:flex;gap:14px;padding:7px 16px;border-bottom:1px solid var(--border);background:rgba(6,8,12,0.8);flex-shrink:0;overflow-x:auto}
.agent-dot{display:flex;align-items:center;gap:5px}
.agent-dot .pip{width:5px;height:5px;border-radius:50%}
.agent-dot .label{font-size:9px;color:var(--text-muted);font-weight:600;letter-spacing:1px}
.agent-bar-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.agent-bar-right span{font-size:9px;color:var(--text-muted);letter-spacing:.5px}

/* Terminal body */
#terminal{flex:1;overflow-y:auto;padding:14px 16px;padding-bottom:calc(14px + var(--safe-bottom))}
#terminal::-webkit-scrollbar{width:3px}
#terminal::-webkit-scrollbar-track{background:transparent}
#terminal::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

.line{animation:lineIn .15s ease-out;font-size:13px;line-height:1.65}
@keyframes lineIn{from{opacity:0;transform:translateY(3px)}to{opacity:1;transform:translateY(0)}}
.line-system{color:var(--text-muted)}
.line-input{display:flex;gap:8px}
.line-input .prompt-char{color:var(--accent);font-weight:700}
.line-input .cmd{color:var(--text)}
.line-agent{display:flex;gap:8px}
.line-agent .agent-tag{font-weight:700;min-width:76px;flex-shrink:0}
.line-data{color:#a0aec0;white-space:pre}
.line-blank{height:10px}
.line-processing{display:flex;align-items:center;gap:8px;color:var(--text-muted);font-size:13px}
.line-processing .dot{animation:blink 1.2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

/* Input area */
#input-area{border-top:1px solid var(--border);background:var(--bg);padding:10px 16px;display:flex;align-items:center;gap:8px;flex-shrink:0;z-index:20}
#input-area .prompt-char{color:var(--accent);font-weight:700;font-size:15px;flex-shrink:0}
#cmd-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;caret-color:var(--accent)}
#cmd-input::placeholder{color:var(--text-muted)}
#cmd-input:disabled{opacity:.4}

/* Voice button */
#voice-btn{padding:7px 12px;border:1px solid var(--border);border-radius:7px;background:var(--accent-dim);cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s;flex-shrink:0}
#voice-btn:hover{border-color:rgba(0,229,160,0.3)}
#voice-btn.listening{border-color:#fb7185;background:rgba(251,113,133,0.1)}
#voice-btn svg{width:13px;height:13px}
#voice-btn .vlabel{font-size:9px;font-weight:600;letter-spacing:1px;color:#a78bfa}
#voice-btn.listening .vlabel{color:#fb7185}
#voice-btn.listening svg{stroke:#fb7185}

/* Voice indicator */
#voice-indicator{display:none;align-items:center;gap:5px;padding:0 10px}
#voice-indicator.active{display:flex}
#voice-indicator .rec-dot{width:6px;height:6px;border-radius:50%;background:#fb7185;animation:blink 1.2s ease-in-out infinite}
#voice-indicator .bars{display:flex;align-items:center;gap:2px;height:16px}
#voice-indicator .bar{width:2px;border-radius:1px;background:var(--accent);transition:height .1s ease}
#voice-indicator .rec-label{font-size:9px;color:var(--accent);font-weight:600;letter-spacing:1px}

/* Quick actions */
#quick-actions{border-top:1px solid rgba(21,27,37,0.5);background:rgba(6,8,12,0.95);padding:7px 16px;padding-bottom:max(var(--safe-bottom),7px);display:flex;gap:7px;overflow-x:auto;flex-shrink:0;z-index:20}
.qbtn{background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:6px;padding:5px 13px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text-muted);cursor:pointer;white-space:nowrap;letter-spacing:.5px;transition:all .15s}
.qbtn:hover{border-color:rgba(0,229,160,0.25);color:var(--accent)}

/* Settings panel */
#settings-panel{position:fixed;inset:0;z-index:50;background:rgba(6,8,12,0.94);backdrop-filter:blur(40px);-webkit-backdrop-filter:blur(40px);display:flex;flex-direction:column;padding:max(var(--safe-top),20px) 20px 20px;transform:translateX(100%);transition:transform .35s cubic-bezier(.16,1,.3,1);overflow-y:auto}
#settings-panel.open{transform:translateX(0)}
.settings-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}
.settings-header h2{font-family:'Outfit',sans-serif;font-size:20px;font-weight:700;letter-spacing:1px}
.settings-close{width:34px;height:34px;border-radius:8px;background:var(--bg-raised);border:1px solid var(--border);color:var(--text-dim);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s}
.settings-close:hover{color:var(--text);border-color:var(--border-focus)}
.settings-section{margin-bottom:24px}
.settings-section h3{font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px}
.settings-user{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--bg-raised);border-radius:12px;border:1px solid var(--border)}
.settings-user .avatar{width:40px;height:40px;border-radius:8px;background:linear-gradient(135deg,#7c3aed,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#06080c;font-family:'Outfit',sans-serif}
.settings-user .info{flex:1}
.settings-user .name{font-size:14px;font-weight:600;font-family:'Outfit',sans-serif}
.settings-user .email{font-size:11px;color:var(--text-dim);margin-top:2px}
.credit-pack{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;background:var(--bg-raised);border:1px solid var(--border);border-radius:10px;margin-bottom:6px;cursor:pointer;transition:all .2s}
.credit-pack:hover{border-color:rgba(0,229,160,0.25);background:var(--accent-dim);transform:translateY(-1px)}
.credit-pack .pack-info{font-size:13px;font-weight:500;font-family:'Outfit',sans-serif}
.credit-pack .pack-credits{font-size:11px;color:var(--text-dim);margin-top:2px}
.credit-pack .pack-price{font-size:14px;font-weight:700;color:var(--accent);font-family:'Outfit',sans-serif}
.settings-btn-full{width:100%;padding:12px;border:1px solid var(--border);border-radius:10px;background:var(--bg-raised);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;cursor:pointer;transition:all .2s}
.settings-btn-full:hover{border-color:var(--border-focus)}
.settings-btn-full.danger{color:var(--danger);border-color:rgba(251,113,133,0.15)}
.settings-btn-full.danger:hover{border-color:var(--danger);background:rgba(251,113,133,0.06)}

/* No credits overlay */
#no-credits-overlay{position:fixed;inset:0;z-index:40;background:rgba(6,8,12,0.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);display:none;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:24px}
#no-credits-overlay.show{display:flex}
#no-credits-overlay h2{font-family:'Outfit',sans-serif;font-size:22px;font-weight:700}
#no-credits-overlay p{color:var(--text-dim);font-size:13px;text-align:center;max-width:280px;line-height:1.5}

/* Scanline overlay */
#scanline{position:fixed;inset:0;background:repeating-linear-gradient(0deg,rgba(167,139,250,0.006) 0px,rgba(167,139,250,0.006) 1px,transparent 1px,transparent 3px);pointer-events:none;z-index:1}
/* Vignette */
#vignette{position:fixed;inset:0;background:radial-gradient(ellipse at center,transparent 55%,rgba(0,0,0,0.35) 100%);pointer-events:none;z-index:1}

@media(min-width:768px){
  #terminal{padding:16px 24px}
  #input-area{padding:12px 24px}
  #quick-actions{padding:8px 24px}
  #agent-bar{padding:7px 24px}
  #header{padding:max(var(--safe-top),12px) 24px 10px}
}
</style>
</head>
<body>
<div id="scanline"></div>
<div id="vignette"></div>

<!-- ============ AUTH SCREEN ============ -->
<div id="auth-screen">
  <img src="/logo.png" style="width:80px;height:80px;border-radius:20px;margin-bottom:8px;filter:drop-shadow(0 0 24px rgba(167,139,250,0.2))" alt="Euphorie" onerror="this.style.display='none'">
  <div class="auth-logo">Euphorie</div>
  <div class="auth-sub">Agent Command Center</div>
  <div id="auth-error" class="auth-error"></div>
  <button class="auth-btn" id="google-btn" onclick="authGoogle()"><svg viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>Continue with Google</button>
  <button class="auth-btn" id="apple-btn" onclick="authApple()"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>Continue with Apple</button>
  <button class="auth-btn" id="ms-btn" onclick="authMicrosoft()"><svg viewBox="0 0 24 24" fill="none"><rect x="1" y="1" width="10" height="10" fill="#F25022"/><rect x="13" y="1" width="10" height="10" fill="#7FBA00"/><rect x="1" y="13" width="10" height="10" fill="#00A4EF"/><rect x="13" y="13" width="10" height="10" fill="#FFB900"/></svg>Continue with Microsoft</button>
  <div class="auth-divider">or</div>
  <button class="auth-btn" onclick="toggleEmailForm()" id="email-toggle-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M2 7l10 7 10-7"/></svg>Continue with Email</button>
  <form class="auth-email-form" id="email-form" onsubmit="authEmail(event)">
    <input type="email" class="auth-input" id="auth-email" placeholder="Email" required autocomplete="email">
    <input type="password" class="auth-input" id="auth-password" placeholder="Password" required autocomplete="current-password">
    <input type="text" class="auth-input" id="auth-name" placeholder="Display name" autocomplete="name" style="display:none">
    <button type="submit" class="auth-submit" id="auth-submit-btn">Sign In</button>
    <button type="button" class="auth-toggle" id="auth-mode-toggle" onclick="toggleAuthMode()">Don't have an account? Sign up</button>
  </form>
  <div style="display:flex;gap:12px;margin-top:16px;position:relative;z-index:1">
    <a href="https://apps.apple.com/us/app/euphorie/id6748045172" target="_blank" style="display:inline-block;height:36px"><img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" style="height:36px;border-radius:6px"></a>
    <a href="https://play.google.com/store/apps/details?id=com.euphorie.app" target="_blank" style="display:inline-block;height:36px;overflow:hidden"><img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" style="height:52px;margin:-8px 0"></a>
  </div>
</div>

<!-- ============ TERMINAL APP ============ -->
<div id="app">
  <!-- Header -->
  <div id="header">
    <div class="header-brand">Euphorie</div>
    <div class="header-meta">
      <span id="header-time"></span>
      <div id="header-credits" onclick="openSettings()">
        <span class="dot"></span>
        <span id="credits-count">0</span> credits
      </div>
      <button id="settings-btn" onclick="openSettings()" style="background:none;border:1px solid var(--border);border-radius:6px;padding:5px 8px;cursor:pointer;color:var(--text-dim);font-family:'JetBrains Mono',monospace;font-size:10px;transition:all .2s">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.73 12.73l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
    </div>
  </div>

  <!-- Agent status bar -->
  <div id="agent-bar">
    <div class="agent-dot"><div class="pip" style="background:#a78bfa;box-shadow:0 0 5px rgba(167,139,250,0.3)"></div><div class="label">ATLAS</div></div>
    <div class="agent-dot"><div class="pip" style="background:#00b4ff;box-shadow:0 0 5px rgba(0,180,255,0.3)"></div><div class="label">CIPHER</div></div>
    <div class="agent-dot"><div class="pip" style="background:#ff6b35;box-shadow:0 0 5px rgba(255,107,53,0.3)"></div><div class="label">ORACLE</div></div>
    <div class="agent-dot"><div class="pip" style="background:#00e5a0;box-shadow:0 0 5px rgba(0,229,160,0.3)"></div><div class="label">HERALD</div></div>
    <div class="agent-dot"><div class="pip" style="background:#ffd93d;box-shadow:0 0 5px rgba(255,217,61,0.3)"></div><div class="label">SENTINEL</div></div>
    <div class="agent-bar-right">
      <span>authe.me ✓</span>
      <span>openclaw ✓</span>
    </div>
  </div>

  <!-- Terminal output -->
  <div id="terminal"></div>

  <!-- Input -->
  <div id="input-area">
    <span class="prompt-char">❯</span>
    <input id="cmd-input" type="text" placeholder="type a command or speak..." autocomplete="off" spellcheck="false">
    <div id="voice-indicator">
      <div class="rec-dot"></div>
      <div class="bars"><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div></div>
      <div class="rec-label">LISTENING</div>
    </div>
    <button id="voice-btn" onclick="toggleVoice()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      <span class="vlabel">VOICE</span>
    </button>
  </div>

  <!-- Quick actions -->
  <div id="quick-actions">
    <button class="qbtn" onclick="runCommand('morning')">morning</button>
    <button class="qbtn" onclick="runCommand('agents')">agents</button>
    <button class="qbtn" onclick="runCommand('research')">research</button>
    <button class="qbtn" onclick="runCommand('status')">status</button>
    <button class="qbtn" onclick="runCommand('help')">help</button>
  </div>
</div>

<!-- ============ SETTINGS PANEL ============ -->
<div id="settings-panel">
  <div class="settings-header"><h2>Settings</h2><button class="settings-close" onclick="closeSettings()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button></div>
  <div class="settings-section"><h3>Account</h3><div class="settings-user"><div class="avatar" id="user-avatar">?</div><div class="info"><div class="name" id="user-name">...</div><div class="email" id="user-email">...</div></div></div></div>
  <div class="settings-section"><h3>Buy Credits</h3><div id="packs-list">Loading...</div></div>
  <div class="settings-section"><h3>Usage</h3><div style="padding:12px 16px;background:var(--bg-raised);border-radius:10px;border:1px solid var(--border);font-size:12px;line-height:2.2"><div>Credits used: <strong id="stat-used" style="color:var(--accent)">0</strong></div><div>Credits purchased: <strong id="stat-purchased" style="color:var(--accent)">0</strong></div></div></div>
  <div class="settings-section"><button class="settings-btn-full danger" onclick="logout()">Sign Out</button></div>
</div>

<!-- ============ NO CREDITS ============ -->
<div id="no-credits-overlay">
  <h2>Out of Credits</h2>
  <p>Purchase more credits to continue delegating tasks to your AI team</p>
  <button class="auth-submit" style="width:220px" onclick="closeNoCredits();openSettings()">Buy Credits</button>
  <button class="auth-toggle" onclick="closeNoCredits()">Maybe later</button>
</div>

<script>
// ============================================
// CONFIG
// ============================================
const API = '';
const GOOGLE_CLIENT_ID = '271690446038-a1c3v0vcc9qk6sdjn5jmgeir3n6256m8.apps.googleusercontent.com';
const MS_CLIENT_ID = 'f8d15ce5-2c27-41cf-a8db-1e7c84ec0c11';
const MS_TENANT_ID = '49a31049-7b61-4fae-bce8-5e9a2ce13434';

const AGENTS = [
  { name: 'ATLAS',    color: '#a78bfa', role: 'Research & Intelligence' },
  { name: 'CIPHER',   color: '#00b4ff', role: 'Code & Engineering' },
  { name: 'ORACLE',   color: '#ff6b35', role: 'Prediction & Analysis' },
  { name: 'HERALD',   color: '#00e5a0', role: 'Communication & Drafts' },
  { name: 'SENTINEL', color: '#ffd93d', role: 'Monitoring & Alerts' },
];

// ============================================
// STATE
// ============================================
let token = localStorage.getItem('euphorie_token');
let refreshToken = localStorage.getItem('euphorie_refresh');
let user = JSON.parse(localStorage.getItem('euphorie_user') || 'null');
let credits = 0, isListening = false, recognition = null;
let isAuthMode = 'login', msalInstance = null, isProcessing = false;
let commandHistory = JSON.parse(localStorage.getItem('euphorie_cmd_history') || '[]');
let historyIndex = -1;
let ws = null;
let wsReconnectTimer = null;
const WS_URL = 'wss://api.authe.me/v1/ws';

// ============================================
// INIT
// ============================================
window.addEventListener('DOMContentLoaded', () => {
  if (token && user) showApp();
  initMSAL();
  updateClock();
  setInterval(updateClock, 30000);
});

function updateClock() {
  const el = document.getElementById('header-time');
  if (el) el.textContent = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
}

// ============================================
// TERMINAL ENGINE
// ============================================
const term = document.getElementById('terminal');

function addLine(type, content, agentName) {
  const div = document.createElement('div');
  div.className = 'line';

  if (type === 'blank') {
    div.className = 'line line-blank';
  } else if (type === 'system') {
    div.className = 'line line-system';
    div.textContent = content;
  } else if (type === 'input') {
    div.className = 'line line-input';
    div.innerHTML = '<span class="prompt-char">❯</span><span class="cmd">' + escapeHtml(content) + '</span>';
  } else if (type === 'agent') {
    div.className = 'line line-agent';
    const agent = AGENTS.find(a => a.name === agentName) || AGENTS[0];
    div.innerHTML = '<span class="agent-tag" style="color:' + agent.color + '">[' + agent.name + ']</span><span>' + escapeHtml(content) + '</span>';
  } else if (type === 'data') {
    div.className = 'line line-data';
    div.textContent = content;
  }

  term.appendChild(div);
  term.scrollTop = term.scrollHeight;
  return div;
}

function showProcessing() {
  const div = document.createElement('div');
  div.className = 'line line-processing';
  div.id = 'processing-line';
  div.innerHTML = '<span class="dot">●</span><span>processing...</span>';
  term.appendChild(div);
  term.scrollTop = term.scrollHeight;
}

function hideProcessing() {
  const el = document.getElementById('processing-line');
  if (el) el.remove();
}

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function streamLines(lines, onDone) {
  isProcessing = true;
  document.getElementById('cmd-input').disabled = true;
  let i = 0;
  function next() {
    if (i >= lines.length) {
      isProcessing = false;
      document.getElementById('cmd-input').disabled = false;
      document.getElementById('cmd-input').focus();
      if (onDone) onDone();
      return;
    }
    const l = lines[i];
    const delay = l.delay || 0;
    setTimeout(() => {
      if (l.type === 'blank') addLine('blank');
      else addLine(l.type, l.text, l.agent);
      i++;
      next();
    }, i === 0 ? 0 : delay);
  }
  next();
}

// ============================================
// COMMAND HANDLER (WebSocket)
// ============================================
async function runCommand(cmd) {
  if (isProcessing || !cmd.trim()) return;
  const trimmed = cmd.trim();
  const lower = trimmed.toLowerCase();

  // Add to history
  addLine('input', trimmed);
  addLine('blank');
  commandHistory.unshift(trimmed);
  if (commandHistory.length > 50) commandHistory.pop();
  localStorage.setItem('euphorie_cmd_history', JSON.stringify(commandHistory));
  historyIndex = -1;

  // Local-only commands
  if (lower === 'clear') {
    term.innerHTML = '';
    return;
  }
  if (lower === 'history') {
    const lines = commandHistory.slice(0, 15);
    addLine('system', 'COMMAND HISTORY');
    lines.forEach((c, i) => addLine('data', '  ' + (i + 1).toString().padStart(2) + '  ' + c));
    addLine('blank');
    return;
  }

  // Send to adapter via WebSocket (with credit gate)
  if (ws && ws.readyState === WebSocket.OPEN) {
    isProcessing = true;
    document.getElementById("cmd-input").disabled = true;
    try {
      const res = await apiFetch("/api/v1/credits/deduct/", { method: "POST" });
      if (res.ok) {
        credits--;
        updateCreditsDisplay();
        ws.send(JSON.stringify({ type: "command", text: trimmed }));
      } else {
        isProcessing = false;
        document.getElementById("cmd-input").disabled = false;
        document.getElementById("no-credits-overlay").classList.add("show");
      }
    } catch(e) {
      isProcessing = false;
      document.getElementById("cmd-input").disabled = false;
      addLine("system", "Credit check failed. Try again.");
    }
  } else {
    addLine("system", "Not connected to agent runtime. Reconnecting...");
    connectWebSocket();
  }









}

// ============================================
// INPUT HANDLING
// ============================================
document.addEventListener('keydown', (e) => {
  const input = document.getElementById('cmd-input');
  if (document.getElementById('auth-screen').classList.contains('hidden') === false) return;
  if (document.getElementById('settings-panel').classList.contains('open')) return;

  if (e.key === 'Enter' && !document.getElementById('cmd-input').disabled) {
    const val = input.value.trim();
    if (val) { runCommand(val); input.value = ''; }
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (historyIndex < commandHistory.length - 1) {
      historyIndex++;
      input.value = commandHistory[historyIndex];
    }
  } else if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (historyIndex > 0) { historyIndex--; input.value = commandHistory[historyIndex]; }
    else { historyIndex = -1; input.value = ''; }
  } else if (e.key === 'l' && e.ctrlKey) {
    e.preventDefault();
    term.innerHTML = '';
  }
});

// ============================================
// VOICE
// ============================================
function initSpeechRecognition() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) return;
  recognition = new SR();
  recognition.continuous = false;
  recognition.interimResults = true;
  recognition.lang = 'en-US';
  recognition.onresult = (e) => {
    const transcript = e.results[0][0].transcript;
    document.getElementById('cmd-input').value = transcript;
    if (e.results[0].isFinal) {
      stopVoice();
      if (transcript.trim()) runCommand(transcript.trim());
    }
  };
  recognition.onerror = () => stopVoice();
  recognition.onend = () => { if (isListening) stopVoice(); };
}

function toggleVoice() {
  if (isListening) { recognition?.stop(); stopVoice(); }
  else startVoice();
}

function startVoice() {
  if (!recognition) { initSpeechRecognition(); if (!recognition) return; }
  isListening = true;
  document.getElementById('voice-btn').classList.add('listening');
  document.getElementById('voice-btn').querySelector('.vlabel').textContent = 'STOP';
  document.getElementById('voice-indicator').classList.add('active');
  startVoiceBars();
  try { recognition.start(); } catch(e) {}
}

function stopVoice() {
  isListening = false;
  document.getElementById('voice-btn').classList.remove('listening');
  document.getElementById('voice-btn').querySelector('.vlabel').textContent = 'VOICE';
  document.getElementById('voice-indicator').classList.remove('active');
  stopVoiceBars();
}

let voiceBarsInterval = null;
function startVoiceBars() {
  const bars = document.querySelectorAll('#voice-indicator .bar');
  voiceBarsInterval = setInterval(() => {
    bars.forEach(b => { b.style.height = (3 + Math.random() * 13) + 'px'; });
  }, 100);
}
function stopVoiceBars() {
  clearInterval(voiceBarsInterval);
  document.querySelectorAll('#voice-indicator .bar').forEach(b => { b.style.height = '3px'; });
}

// ============================================
// MICROSOFT MSAL INIT
// ============================================
function initMSAL() {
  try {
    msalInstance = new msal.PublicClientApplication({
      auth: {
        clientId: MS_CLIENT_ID,
        authority: 'https://login.microsoftonline.com/common',
        redirectUri: window.location.origin,
      },
      cache: { cacheLocation: 'localStorage' },
    });
  } catch (e) { console.error('MSAL init error:', e); }
}

// ============================================
// GOOGLE AUTH
// ============================================
function authGoogle() {
  const btn = document.getElementById('google-btn');
  btn.disabled = true;
  btn.textContent = 'Signing in...';
  try {
    const tokenClient = google.accounts.oauth2.initTokenClient({
      client_id: GOOGLE_CLIENT_ID,
      scope: 'email profile',
      callback: async (tokenResponse) => {
        if (tokenResponse.error) { showAuthError('Google sign-in failed'); resetBtn(btn, 'Continue with Google'); return; }
        try {
          const res = await fetch(API + '/api/auth/google/', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ access_token: tokenResponse.access_token }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Google auth failed');
          handleAuthSuccess(data);
        } catch (err) { showAuthError(err.message); }
        finally { resetBtn(btn, 'Continue with Google'); }
      },
    });
    tokenClient.requestAccessToken();
  } catch (err) { showAuthError('Google sign-in unavailable'); resetBtn(btn, 'Continue with Google'); }
}

// ============================================
// APPLE AUTH
// ============================================
async function authApple() {
  const btn = document.getElementById('apple-btn');
  btn.disabled = true;
  btn.textContent = 'Signing in...';
  try {
    AppleID.auth.init({
      clientId: 'com.euphorie.web',
      scope: 'name email',
      redirectURI: 'https://euphorie.com/accounts/apple/login/callback/',
      state: Math.random().toString(36).substring(2),
      usePopup: true,
    });
    const response = await AppleID.auth.signIn();
    const idToken = response.authorization.id_token;
    const userData = response.user || {};
    const res = await fetch(API + '/api/auth/apple/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id_token: idToken,
        email: userData.email || '',
        displayName: userData.name ? (userData.name.firstName || '') + ' ' + (userData.name.lastName || '') : '',
      }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Apple auth failed');
    handleAuthSuccess(data);
  } catch (err) {
    if (err.error !== 'popup_closed_by_user') showAuthError(err.message || 'Apple sign-in failed');
  } finally { resetBtn(btn, 'Continue with Apple'); }
}

// ============================================
// MICROSOFT AUTH
// ============================================
async function authMicrosoft() {
  const btn = document.getElementById('ms-btn');
  btn.disabled = true;
  if (!msalInstance) { showAuthError('Microsoft sign-in unavailable'); resetBtn(btn, 'Continue with Microsoft'); return; }
  try {
    const loginResponse = await msalInstance.loginPopup({ scopes: ['User.Read', 'email', 'profile'], prompt: 'select_account' });
    const res = await fetch(API + '/api/auth/microsoft/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ access_token: loginResponse.accessToken, email: loginResponse.account?.username, displayName: loginResponse.account?.name || '' }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Microsoft auth failed');
    handleAuthSuccess(data);
  } catch (err) { if (err.errorCode !== 'user_cancelled') showAuthError(err.message || 'Microsoft sign-in failed'); }
  finally { resetBtn(btn, 'Continue with Microsoft'); }
}

// ============================================
// EMAIL AUTH
// ============================================
function toggleEmailForm() {
  const f = document.getElementById('email-form');
  f.classList.toggle('show');
  document.getElementById('email-toggle-btn').style.display = f.classList.contains('show') ? 'none' : 'flex';
}

function toggleAuthMode() {
  isAuthMode = isAuthMode === 'login' ? 'register' : 'login';
  document.getElementById('auth-submit-btn').textContent = isAuthMode === 'login' ? 'Sign In' : 'Create Account';
  document.getElementById('auth-mode-toggle').textContent = isAuthMode === 'login'
    ? "Don't have an account? Sign up" : "Already have an account? Sign in";
  document.getElementById('auth-name').style.display = isAuthMode === 'register' ? 'block' : 'none';
}

async function authEmail(e) {
  e.preventDefault();
  const email = document.getElementById('auth-email').value;
  const password = document.getElementById('auth-password').value;
  const name = document.getElementById('auth-name').value;
  const endpoint = isAuthMode === 'login' ? '/api/auth/login/' : '/api/auth/register/';
  const body = { email, password };
  if (isAuthMode === 'register' && name) body.display_name = name;
  try {
    const res = await fetch(API + endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Auth failed');
    handleAuthSuccess(data);
  } catch (err) { showAuthError(err.message); }
}

// ============================================
// AUTH UTILITIES
// ============================================
function showAuthError(msg) {
  const el = document.getElementById('auth-error');
  el.textContent = msg;
  setTimeout(() => el.textContent = '', 5000);
}

function resetBtn(btn, label) {
  btn.disabled = false;
  const svg = btn.querySelector('svg');
  if (svg) { btn.textContent = ''; btn.appendChild(svg); btn.append(label); }
  else btn.textContent = label;
}

function handleAuthSuccess(data) {
  token = data.access_token;
  refreshToken = data.refresh_token;
  user = { id: data.user_id, email: data.email, name: data.display_name };
  localStorage.setItem('euphorie_token', token);
  localStorage.setItem('euphorie_refresh', refreshToken);
  localStorage.setItem('euphorie_user', JSON.stringify(user));
  showApp();
}

// ============================================
// WEBSOCKET CONNECTION
// ============================================
function connectWebSocket() {
  if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) return;

  ws = new WebSocket(WS_URL);

  ws.onopen = () => {
    console.log('WebSocket connected');
    // Authenticate with the adapter
    ws.send(JSON.stringify({
      type: 'auth',
      email: user?.email || '',
      name: user?.name || '',
      token: token || '',
    }));
  };

  ws.onmessage = (event) => {
    try {
      const msg = JSON.parse(event.data);

      if (msg.type === 'auth_ok') {
        console.log('Adapter authenticated:', msg.ownerId);
        return;
      }

      if (msg.type === 'ready') {
        isProcessing = false;
        document.getElementById('cmd-input').disabled = false;
        document.getElementById('cmd-input').focus();
        return;
      }

      // Terminal line types
      // The adapter sends: sendEvent(ws, 'line', { type: 'system', text: '...' })
      // which becomes: { type: 'system', text: '...', ts: 123 } (inner type overwrites outer)
      if (msg.type === 'system' || msg.type === 'data') {
        addLine(msg.type, msg.text || '');
        term.scrollTop = term.scrollHeight;
        return;
      }

      if (msg.type === 'agent') {
        addLine('agent', msg.text || '', msg.agent || 'ATLAS');
        term.scrollTop = term.scrollHeight;
        return;
      }

      if (msg.type === 'blank') {
        addLine('blank');
        term.scrollTop = term.scrollHeight;
        return;
      }

      if (msg.type === 'turn_start') {
        return;
      }

      if (msg.type === 'turn_complete') {
        isProcessing = false;
        document.getElementById('cmd-input').disabled = false;
        document.getElementById('cmd-input').focus();
        return;
      }

      if (msg.type === 'error') {
        addLine('system', 'Error: ' + (msg.message || 'Unknown error'));
        isProcessing = false;
        document.getElementById('cmd-input').disabled = false;
        return;
      }

    } catch (err) {
      console.error('WS message parse error:', err);
    }
  };

  ws.onclose = () => {
    console.log('WebSocket disconnected');
    isProcessing = false;
    document.getElementById('cmd-input').disabled = false;
    // Reconnect after 3 seconds
    clearTimeout(wsReconnectTimer);
    wsReconnectTimer = setTimeout(() => {
      if (token && user) connectWebSocket();
    }, 3000);
  };

  ws.onerror = (err) => {
    console.error('WebSocket error:', err);
  };
}

// ============================================
// SHOW APP (terminal mode)
// ============================================
async function showApp() {
  document.getElementById('auth-screen').classList.add('hidden');
  document.getElementById('app').classList.add('visible');

  if (user) {
    document.getElementById('user-name').textContent = user.name || user.email.split('@')[0];
    document.getElementById('user-email').textContent = user.email;
    document.getElementById('user-avatar').textContent = (user.name || user.email)[0].toUpperCase();
  }

  await loadCredits();
  initSpeechRecognition();

  // Connect WebSocket to adapter (boot sequence comes from server)
  connectWebSocket();

  // Click anywhere on terminal to focus input
  document.getElementById('terminal').addEventListener('click', () => {
    const input = document.getElementById('cmd-input');
    input.disabled = false; isProcessing = false;
    input.focus();
  });
  document.getElementById('input-area').addEventListener('click', () => {
    const input = document.getElementById('cmd-input');
    input.disabled = false; isProcessing = false;
    input.focus();
  });

  // Safety: re-enable input after 30 seconds max (prevents stuck state)
  setInterval(() => {
    if (isProcessing) {
      const input = document.getElementById('cmd-input');
      if (input.disabled) {
        isProcessing = false;
        input.disabled = false; isProcessing = false;
      }
    }
  }, 30000);
}

// ============================================
// CREDITS
// ============================================
async function loadCredits() {
  try {
    const res = await apiFetch('/api/v1/credits/');
    const data = await res.json();
    if (res.ok) {
      credits = data.balance;
      updateCreditsDisplay();
      document.getElementById('stat-used').textContent = data.total_used;
      document.getElementById('stat-purchased').textContent = data.total_purchased;
      renderPacks(data.packs);
    }
  } catch (err) {}
}

function updateCreditsDisplay() {
  document.getElementById('credits-count').textContent = credits;
  document.getElementById('header-credits').classList.toggle('low', credits <= 5);
}

function renderPacks(packs) {
  document.getElementById('packs-list').innerHTML = packs.map(p => `
    <div class="credit-pack" onclick="purchasePack(${p.id})">
      <div><div class="pack-info">${p.credits} Credits</div><div class="pack-credits">${p.name}</div></div>
      <span class="pack-price">$${(p.price_cents / 100).toFixed(2)}</span>
    </div>`).join('');
}

async function purchasePack(packId) {
  try {
    const res = await apiFetch('/api/v1/credits/purchase/', { method: 'POST', body: JSON.stringify({ pack_id: packId }) });
    const data = await res.json();
    if (res.ok && data.checkout_url) window.location.href = data.checkout_url;
    else alert(data.error || 'Purchase failed');
  } catch (err) { alert('Purchase error.'); }
}

// ============================================
// SETTINGS
// ============================================
function openSettings() { document.getElementById('settings-panel').classList.add('open'); }
function closeSettings() { document.getElementById('settings-panel').classList.remove('open'); }
function closeNoCredits() { document.getElementById('no-credits-overlay').classList.remove('show'); }

// ============================================
// API + AUTH
// ============================================
async function apiFetch(path, options = {}) {
  const headers = { 'Content-Type': 'application/json', ...options.headers };
  if (token) headers['Authorization'] = `Bearer ${token}`;
  const res = await fetch(API + path, { ...options, headers });
  if (res.status === 401 && refreshToken) {
    const ok = await refreshAccessToken();
    if (ok) { headers['Authorization'] = `Bearer ${token}`; return fetch(API + path, { ...options, headers }); }
    else logout();
  }
  return res;
}

async function refreshAccessToken() {
  try {
    const res = await fetch(API + '/api/auth/refresh/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refresh_token: refreshToken }),
    });
    if (!res.ok) return false;
    const data = await res.json();
    token = data.access_token; refreshToken = data.refresh_token;
    localStorage.setItem('euphorie_token', token);
    localStorage.setItem('euphorie_refresh', refreshToken);
    return true;
  } catch { return false; }
}

function logout() {
  apiFetch('/api/auth/logout/', { method: 'POST', body: JSON.stringify({ refresh_token: refreshToken }) }).catch(() => {});
  if (ws) { ws.close(); ws = null; }
  clearTimeout(wsReconnectTimer);
  token = null; refreshToken = null; user = null;
  localStorage.removeItem('euphorie_token');
  localStorage.removeItem('euphorie_refresh');
  localStorage.removeItem('euphorie_user');
  document.getElementById('auth-screen').classList.remove('hidden');
  document.getElementById('app').classList.remove('visible');
  closeSettings();
  term.innerHTML = '';
}

// ============================================
// REDIRECTS
// ============================================
// Handle Apple auth redirect
const hashParams = new URLSearchParams(window.location.hash.substring(1));
if (hashParams.get('access_token') && new URLSearchParams(window.location.search).get('apple_auth') === 'success') {
  handleAuthSuccess({
    access_token: hashParams.get('access_token'),
    refresh_token: hashParams.get('refresh_token'),
    user_id: hashParams.get('user_id'),
    email: hashParams.get('email'),
    display_name: hashParams.get('display_name'),
  });
  window.history.replaceState({}, '', '/');
}

// Handle purchase redirect
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('purchase') === 'success') {
  window.history.replaceState({}, '', '/');
  if (token) setTimeout(() => loadCredits(), 500);
}
</script>
</body>
</html>
